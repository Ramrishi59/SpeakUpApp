rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function safeUserCreate(uid) {
      return isOwner(uid)
        && request.resource.data.get("fullUnlock", false) == false
        && request.resource.data.get("role", "user") == "user"
        && request.resource.data.licenseExpiresAt == null
        && request.resource.data.trialExpiresAt == null;
    }

    function safeUserUpdate() {
      return changedKeys().hasOnly([
        "username",
        "email",
        "avatarName",
        "avatarSrc",
        "lastOpenedUnit",
        "lastScreenIndex",
        "openedUnits",
        "completedUnits",
        "lessonProgress",
        "lastSeenAt",
        "activePath",
        "activePage",
        "updatedAt",
        "createdAt"
      ]);
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if safeUserCreate(uid);
      allow update: if isOwner(uid) && safeUserUpdate();
      allow delete: if false;
    }

    match /payments/{paymentId} {
      allow read, write: if false;
    }

    match /adminAuditLogs/{logId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
