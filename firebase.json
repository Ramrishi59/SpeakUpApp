{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".firebase/**",
      ".vscode/**",
      ".git/**",
      ".gitignore",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/index.html"
      },
      {
        "source": "/app",
        "destination": "/app/dashboard.html"
      },
      {
        "source": "/app/",
        "destination": "/app/dashboard.html"
      },
      {
        "source": "/api/create-order",
        "function": "createOrder"
      },
      {
        "source": "/api/verify-payment",
        "function": "verifyPayment"
      },
      {
        "source": "/api/admin/list-users",
        "function": "adminListUsers"
      },
      {
        "source": "/api/admin/get-user",
        "function": "adminGetUser"
      },
      {
        "source": "/api/admin/update-access",
        "function": "adminUpdateAccess"
      },
      {
        "source": "/api/admin/reset-device",
        "function": "adminResetDevice"
      },
      {
        "source": "/api/admin/verify-email",
        "function": "adminVerifyEmail"
      },
      {
        "source": "/api/admin/list-payments",
        "function": "adminListPayments"
      },
      {
        "source": "/api/admin/get-user-progress",
        "function": "adminGetUserProgress"
      }
    ],
    "headers": [
      {
        "source": "**/*.{html,css,js}",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.{webp,jpg,jpeg,png,gif,svg,ico}",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.{mp3,mp4,wav,ogg}",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.json",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  }
}
